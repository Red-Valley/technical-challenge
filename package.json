{
	"name": "technical-challenge",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"dev:frontend": "turbo dev --filter=frontend",
		"dev:backend": "turbo dev --filter=@repo/backend",
		"lint": "turbo lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo check-types",
		"docker:dev": "./docker-scripts.sh dev",
		"docker:build": "./docker-scripts.sh build",
		"docker:stop": "./docker-scripts.sh stop",
		"docker:logs": "./docker-scripts.sh logs",
		"docker:clean": "./docker-scripts.sh clean",
		"docker:status": "./docker-scripts.sh status",
		"prepare": "husky",
		"lint:staged": "lint-staged",
		"lint:all": "turbo lint",
		"format:all": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
		"pre-commit": "lint-staged"
	},
	"devDependencies": {
		"@eslint/js": "^9.30.0",
		"@types/node": "^24.0.7",
		"@typescript-eslint/eslint-plugin": "^8.35.0",
		"@typescript-eslint/parser": "^8.35.0",
		"autoprefixer": "^10.4.21",
		"eslint": "^9.30.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-check-file": "^3.3.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.5",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.13",
		"stylelint": "^16.21.0",
		"stylelint-config-standard": "^38.0.0",
		"stylelint-config-tailwindcss": "^1.0.0",
		"stylelint-order": "^7.0.0",
		"tailwindcss": "^4.1.11",
		"turbo": "^2.5.4",
		"typescript": "5.8.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.2.17",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"lint-staged": {
		"*.{json,md,yml,yaml}": [
			"prettier --write --ignore-unknown"
		],
		"apps/backend/**/*.{ts,js}": [
			"bash -c 'cd apps/backend && bun run lint:fix'",
			"prettier --write --ignore-unknown"
		],
		"apps/frontend/**/*.{ts,tsx,js,jsx}": [
			"bash -c 'cd apps/frontend && bun run lint:fix'",
			"prettier --write --ignore-unknown"
		],
		"packages/**/*.{ts,js}": [
			"prettier --write --ignore-unknown"
		]
	}
}
